{
  "manifest_version": 3,
  "name": "Group Tabs",
  "version": "0.2.0",
  "description": "Auto-group tabs by domain (AI-enhanced when Chrome built-in model is available). Save and restore groups.",
  "permissions": ["tabs", "tabGroups", "storage", "alarms"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
